{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(sf project delete *)",
      "Bash(sf org delete *)",
      "Bash(sf data delete *)",
      "PowerShell(sf project delete *)",
      "PowerShell(sf org delete *)",
      "PowerShell(sf data delete *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/skills/apex-test-loop/scripts/guard.mjs",
            "statusMessage": "apex-test-loop: checando acao destrutiva"
          }
        ]
      }
    ]
  }
}
